# NavIQ backend — environment variables
# Copy this to .env for local dev, or paste into Render dashboard for production.

# Supabase — from your Supabase project's API settings
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=...

# OpenRouteService — free key from https://openrouteservice.org/dev/#/signup
ORS_API_KEY=eyJvcmci...

# Which frontends are allowed to call this API.
# Local dev:       http://localhost:3000
# After deploying: https://your-app.vercel.app
# Multiple values: separate with commas, no spaces around commas
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
