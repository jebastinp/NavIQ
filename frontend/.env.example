# NavIQ frontend — environment variables
# Copy this to .env.local for local dev, or paste into Vercel dashboard for production.

# Supabase — from your Supabase project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Backend API URL
# Local dev:       http://localhost:8000
# After deploying: https://naviq-backend.onrender.com  (your Render URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
